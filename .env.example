# No API keys required! All astrology interpretations are generated locally.
# The app works completely offline - interpretations don't require external services.

# Optional: Supabase Configuration (for user accounts and saving charts)
# Remove these if you don't want to use database features
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Google Maps API (for astrocartography map visualization)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key

# Optional: Other API Keys
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...
